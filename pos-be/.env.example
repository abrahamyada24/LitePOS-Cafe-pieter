NODE_ENV=production
HOST=127.0.0.1
PORT=5000

# Gunakan user database khusus aplikasi. Encode karakter khusus pada password untuk URL.
DATABASE_URL="mysql://litepos:CHANGE_ME@127.0.0.1:3306/litepos"
JWT_SECRET="CHANGE_WITH_A_LONG_RANDOM_SECRET"

# Pisahkan dengan koma. Wildcard opsional, contoh: https://*.vercel.app
CORS_ORIGINS="https://your-pos.vercel.app,https://pos.example.com"

# Folder persisten di luar source code agar gambar tidak hilang saat update aplikasi.
UPLOAD_DIR="/var/lib/litepos/uploads"
ENABLE_API_DOCS=false

# Opsional. Biarkan kosong bila payment gateway belum digunakan.
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION=false

# Opsional untuk OTP/email.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
